{
  "name": "@im/web",
  "version": "1.0.0",
  "description": "IM聊天应用前端",
  "type": "module",
  "scripts": {
    "dev": "vite --mode dev --host --port 3000",
    "dev:sit": "vite --mode sit --host --port 3000",
    "typecheck": "vue-tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "build:dev": "npm run typecheck && vite build --mode dev",
    "build:sit": "npm run typecheck && vite build --mode sit",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write src/",
    "test": "vitest run --coverage",
    "test:unit": "vitest",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap run android",
    "cap:ios": "npx cap run ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/action-sheet": "^8.1.1",
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.3",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@element-plus/icons-vue": "^2.3.1",
    "@vueuse/core": "^12.7.0",
    "axios": "^1.7.9",
    "dayjs": "^1.11.13",
    "element-plus": "^2.9.4",
    "mitt": "^3.0.1",
    "pinia": "^2.3.1",
    "pinyin-pro": "^3.26.0",
    "qs": "^6.14.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vue-virtual-scroller": "^2.0.0-beta.8"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.12.0",
    "@types/qs": "^6.14.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitest/coverage-v8": "^3.0.5",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.3.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.19.0",
    "eslint-plugin-vue": "^9.32.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "sass": "^1.83.4",
    "typescript": "~5.7.3",
    "unplugin-auto-import": "^0.18.6",
    "unplugin-vue-components": "^0.27.5",
    "vite": "^6.0.7",
    "vitest": "^3.0.5",
    "vue-tsc": "^2.2.0"
  },
  "keywords": [
    "vue3",
    "typescript",
    "vite",
    "element-plus",
    "im",
    "chat",
    "websocket"
  ],
  "author": "IM Team",
  "license": "MIT",
  "main": "index.js"
}
