{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "NewIM",
  "identifier": "com.myhzz.newim.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:3001",
    "beforeDevCommand": "cd .. && npx vite --mode dev --port 3001",
    "beforeBuildCommand": "cd .. && npx vite build"
  },
  "app": {
    "windows": [
      {
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "title": "NewIM",
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "notification": {},
    "global-shortcut": {},
    "shell": {
      "open": true
    }
  }
}
