{
  "name": "im-frontend",
  "version": "1.0.0",
  "description": "IM聊天应用前端",
  "type": "module",
  "scripts": {
    "dev": "vite --mode dev --host --port 3000",
    "dev:sit": "vite --mode sit --host --port 3000",
    "typecheck": "vue-tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "build:dev": "npm run typecheck && vite build --mode dev",
    "build:sit": "npm run typecheck && vite build --mode sit",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "lint:check": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore",
    "format": "prettier --write src/",
    "test": "vitest run --coverage",
    "test:unit": "vitest"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.1.0",
    "@vueuse/core": "^10.3.0",
    "axios": "^1.5.0",
    "crypto-js": "^4.1.1",
    "dayjs": "^1.11.9",
    "element-plus": "^2.3.9",
    "js-cookie": "^3.0.5",
    "mitt": "^3.0.1",
    "nprogress": "^0.2.0",
    "pinia": "^2.1.6",
    "pinyin-pro": "^3.27.0",
    "qs": "^6.14.0",
    "vue": "^3.3.4",
    "vue-router": "^4.2.4"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.1.1",
    "@types/js-cookie": "^3.0.3",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.5.0",
    "@types/nprogress": "^0.2.0",
    "@types/qs": "^6.14.0",
    "@vitejs/plugin-vue": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.8",
    "@vue/eslint-config-prettier": "^8.0.0",
    "@vue/eslint-config-typescript": "^11.0.3",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.4.0",
    "eslint": "^8.46.0",
    "eslint-plugin-vue": "^9.16.1",
    "jsdom": "^25.0.1",
    "prettier": "^3.0.1",
    "sass": "^1.64.2",
    "typescript": "~5.1.6",
    "unplugin-auto-import": "^0.16.6",
    "unplugin-vue-components": "^0.25.1",
    "vite": "^4.4.9",
    "vitest": "^2.1.8",
    "vue-tsc": "^1.8.8"
  },
  "keywords": [
    "vue3",
    "typescript",
    "vite",
    "element-plus",
    "im",
    "chat",
    "websocket"
  ],
  "author": "IM Team",
  "license": "MIT",
  "main": "index.js"
}
