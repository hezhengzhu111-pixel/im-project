# SIT环境配置
VITE_APP_ENV=sit

# API配置
VITE_API_BASE_URL=/api
VITE_WS_BASE_URL=
VITE_GATEWAY_HOST=127.0.0.1
VITE_GATEWAY_PORT=8082

# 调试配置
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info

# 功能开关
VITE_ENABLE_PWA=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=false
VITE_ENABLE_MOCK=false
