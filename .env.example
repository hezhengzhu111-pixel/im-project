# Shared auth secrets
JWT_SECRET=replace-with-a-strong-access-secret
JWT_REFRESH_SECRET=replace-with-a-strong-refresh-secret
IM_INTERNAL_SECRET=replace-with-a-strong-internal-secret
IM_GATEWAY_AUTH_SECRET=replace-with-a-strong-gateway-signing-secret
IM_INTERNAL_HEADER=X-Internal-Secret

# Frontend
VITE_API_BASE_URL=/api
VITE_WS_BASE_URL=

# Service database credentials
GROUP_SERVICE_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/service_group_service_db?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
GROUP_SERVICE_DATASOURCE_USERNAME=root
GROUP_SERVICE_DATASOURCE_PASSWORD=replace-me

MESSAGE_SERVICE_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/service_message_service_db?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&cacheServerConfiguration=true&useLocalSessionState=true
MESSAGE_SERVICE_DATASOURCE_USERNAME=root
MESSAGE_SERVICE_DATASOURCE_PASSWORD=replace-me

USER_SERVICE_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/service_user_service_db?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&cacheServerConfiguration=true&useLocalSessionState=true
USER_SERVICE_DATASOURCE_USERNAME=root
USER_SERVICE_DATASOURCE_PASSWORD=replace-me

IM_SERVER_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/service_im_server_db?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai
IM_SERVER_DATASOURCE_USERNAME=root
