# Root .env.example for the Python deployment scripts:
#   1_deploy_middleware.py
#   2_init_db.py
#   3_deploy_services.py
#
# This file can also provide variable interpolation for:
#   deploy/sit/docker-compose.yml
#
# Frontend Vite actually reads frontend/.env*.
# The VITE_* block below is kept here as a root-level reference snapshot
# so deployment and frontend settings can be reviewed in one place.

# Repository and deployment layout
GLOBAL_DOCKER_NETWORK=im-network
GIT_REPO_URL=https://github.com/hezhengzhu111-pixel/im-project.git
GIT_BRANCH=main
BACKEND_CODE_ROOT=backend

# Host-exposed middleware ports
MYSQL_PORT=3306
REDIS_PORT=6379
NACOS_PORT=8848
KAFKA_PORT=9092
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601

# Host-exposed service ports
GATEWAY_PORT=8082
AUTH_SERVICE_PORT=8084
USER_SERVICE_PORT=8085
GROUP_SERVICE_PORT=8086
MESSAGE_SERVICE_PORT=8087
IM_SERVER_PORT=8083
FILE_SERVICE_PORT=8088
LOG_SERVICE_PORT=8091
REGISTRY_MONITOR_PORT=8090
FRONTEND_PORT=80

# Middleware credentials required by deploy_utils.py
# MySQL and Redis are enabled today.
# Nacos, Kafka and Elasticsearch credentials are reserved for future hardening.
MYSQL_ROOT_PASSWORD=change_me_mysql_root
REDIS_PASSWORD=change_me_redis_password
NACOS_USERNAME=nacos
NACOS_PASSWORD=unused
KAFKA_PASSWORD=unused
ELASTICSEARCH_PASSWORD=unused

# Shared backend secrets injected by the Python deployment scripts
JWT_SECRET=change_me_jwt_secret
AUTH_REFRESH_SECRET=change_me_auth_refresh_secret
IM_INTERNAL_SECRET=change_me_internal_secret
IM_GATEWAY_AUTH_SECRET=change_me_gateway_auth_secret

# Docker Compose substitution values used by deploy/sit/docker-compose.yml
HOST_LOG_ROOT=./logs
IM_BUILD_NONCE=manual
FRONTEND_BUILD_MODE=sit

# Optional direct runtime overrides for manual docker run / spring-boot:run
# Use localhost values for local dev, or container names for sit/docker.
IM_MYSQL_HOST=im-mysql
IM_MYSQL_PORT=3306
IM_MYSQL_USERNAME=root
IM_MYSQL_PASSWORD=change_me_mysql_root
IM_REDIS_HOST=im-redis
IM_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=change_me_redis_password
IM_NACOS_SERVER_ADDR=im-nacos:8848
IM_KAFKA_BOOTSTRAP_SERVERS=im-kafka:29092
IM_ES_URIS=http://admin-es:9200
IM_REGISTRY_MONITOR_NACOS_BASE_URL=http://im-nacos:8848/nacos
IM_GATEWAY_AUTH_SERVICE_URL=lb://im-auth-service
IM_ROUTE_AUTH_HOST=im-auth-service
IM_ROUTE_USER_HOST=im-user-service
IM_ROUTE_GROUP_HOST=im-group-service
IM_ROUTE_MESSAGE_HOST=im-message-service
IM_ROUTE_FILE_HOST=im-file-service
IM_ROUTE_IM_SERVER_HOST=im-server
IM_SERVER_URL=http://im-server:8083
IM_SERVER_ROUTE_URI=http://im-server:8083
IM_SERVER_WS_ROUTE_URI=ws://im-server:8083
IM_NATIVE_SERVICES=

# Optional logging and storage overrides
IM_LOGGING_ROOT_DIR=/var/log/im-project
IM_STORAGE_LOCAL_BASE_DIR=/data/im-files

# Optional file-service COS overrides
IM_COS_ENABLED=false
IM_COS_HTTPS=true
IM_COS_SECRET_ID=
IM_COS_SECRET_KEY=
IM_COS_REGION=
IM_COS_BUCKET=
IM_COS_PUBLIC_DOMAIN=
IM_COS_PATH_PREFIX=im

# Frontend Vite reference values
# Actual frontend runtime files live in frontend/.env and frontend/.env.sit.
VITE_APP_TITLE=即时通讯应用
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=一个现代化的即时通讯应用
VITE_APP_ENV=sit
VITE_API_BASE_URL=/api
VITE_WS_BASE_URL=
VITE_GATEWAY_HOST=127.0.0.1
VITE_GATEWAY_PORT=8082
VITE_UPLOAD_MAX_SIZE=10485760
VITE_UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
VITE_ENABLE_PWA=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=false
VITE_ENABLE_MOCK=false
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info

# Notes
# 1. The deployment scripts require the deployment sections above; do not leave them blank.
# 2. REDIS_PASSWORD is used by the deployment scripts and mapped to SPRING_DATA_REDIS_PASSWORD.
# 3. Nacos, Kafka and Elasticsearch auth are disabled in the current sit configuration,
#    so their password fields are intentionally set to `unused`.
# 4. To make deploy/sit/docker-compose.yml read this root file explicitly, run:
#    docker compose --env-file .env -f deploy/sit/docker-compose.yml up -d
