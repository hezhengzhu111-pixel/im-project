# Backend note
# dev and sit backend settings are committed in:
# backend/*/src/main/resources/dev
# backend/*/src/main/resources/sit
#
# Optional backend overrides (shared by all services)
# Dev defaults (run services on host, middlewares in Docker):
JWT_SECRET=im-access-secret-im-access-secret-im-access-secret-im-access-secret
AUTH_REFRESH_SECRET=im-refresh-secret-im-refresh-secret-im-refresh-secret-im-refresh-secret
IM_INTERNAL_SECRET=im-internal-secret-im-internal-secret-im-internal-secret-im
IM_GATEWAY_AUTH_SECRET=im-gateway-auth-secret-im-gateway-auth-secret-im-gateway-auth-secret
IM_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
IM_MYSQL_HOST=127.0.0.1
IM_MYSQL_PORT=3306
IM_MYSQL_USERNAME=root
IM_MYSQL_PASSWORD=root123
IM_REDIS_HOST=127.0.0.1
IM_REDIS_PORT=6379
IM_NACOS_SERVER_ADDR=127.0.0.1:8848
IM_ES_URIS=http://127.0.0.1:9200
IM_REGISTRY_MONITOR_NACOS_BASE_URL=http://127.0.0.1:8848/nacos
IM_GATEWAY_AUTH_SERVICE_URL=http://127.0.0.1:8084
IM_SELF_URL=http://127.0.0.1:8083
IM_ROUTE_AUTH_HOST=127.0.0.1
IM_ROUTE_USER_HOST=127.0.0.1
IM_ROUTE_GROUP_HOST=127.0.0.1
IM_ROUTE_MESSAGE_HOST=127.0.0.1
IM_ROUTE_FILE_HOST=127.0.0.1
IM_ROUTE_IM_SERVER_HOST=127.0.0.1
