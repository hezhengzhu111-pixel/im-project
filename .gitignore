target/
# Compiled class file
*.class
node_modules/
dist/
.idea/
.vscode/
__pycache__/
*.pyc
logs/
test_reports/
test_report_*.json
.deploy-tools/
.maven-repository/

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*
