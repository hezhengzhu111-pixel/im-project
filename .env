# Runtime configuration for the Rust-only local/SIT stack.

# Repository layout
BACKEND_CODE_ROOT=backend
GLOBAL_DOCKER_NETWORK=im-sit-network

# Host ports
MYSQL_PORT=3306
REDIS_PORT=6379
GATEWAY_PORT=8082
IM_SERVER_PORT=8083
FRONTEND_PORT=80

# Middleware credentials
MYSQL_ROOT_PASSWORD=root123
REDIS_PASSWORD=root123

# Backend secrets
JWT_SECRET=im-access-secret-im-access-secret-im-access-secret-im-access-secret
AUTH_REFRESH_SECRET=im-refresh-secret-im-refresh-secret-im-refresh-secret-im-refresh-secret
IM_INTERNAL_SECRET=im-internal-secret-im-internal-secret-im-internal-secret-im
IM_GATEWAY_AUTH_SECRET=im-gateway-auth-secret-im-gateway-auth-secret-im-gateway-auth-secret

# Docker Compose substitution values
IM_BUILD_NONCE=manual
FRONTEND_BUILD_MODE=sit

# Rust API server
API_SERVER_RUST_LOG=api_server_rs=info,im_observe=info,tower_http=warn,sqlx::query=off
IM_EVENT_STREAM_KEY=im:events
IM_EVENT_STREAM_MAX_LEN=100000
IM_EVENT_STREAM_BLOCK_MS=1000
IM_WRITER_BATCH_SIZE=1000
IM_WRITER_FLUSH_INTERVAL_MS=1000
IM_PUSH_DISPATCHER_ENABLED=true

# Local file storage
IM_STORAGE_LOCAL_BASE_DIR=/data/im-files
IM_FILE_IMAGE_MAX_SIZE=20971520
IM_FILE_FILE_MAX_SIZE=536870912
IM_FILE_AUDIO_MAX_SIZE=104857600
IM_FILE_VIDEO_MAX_SIZE=1073741824
IM_FILE_AVATAR_MAX_SIZE=5242880
IM_FILE_MULTIPART_MAX_BYTES=1082130432

# Test script defaults
IM_API_BASE=http://localhost:8082
IM_MYSQL_CONTAINER=sit-im-mysql-1
IM_REDIS_CONTAINER=sit-im-redis-1

# Frontend build reference values. Frontend runtime files live under frontend/.env*.
VITE_APP_ENV=sit
VITE_API_BASE_URL=/api
VITE_WS_BASE_URL=
VITE_GATEWAY_HOST=127.0.0.1
VITE_GATEWAY_PORT=8082
VITE_UPLOAD_MAX_SIZE=10485760
VITE_ENABLE_MOCK=false
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info
